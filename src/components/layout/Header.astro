---
import { menuLinks, siteConfig } from "@/site-config";
import { withBase } from "@/utils/path";
import { Icon } from "astro-icon/components";

const url = new URL(Astro.request.url);
const wordmark = siteConfig.title;

const normalize = (path: string) => (path.endsWith("/") ? path : `${path}/`);

const isActive = (path: string) => {
	const target = withBase(path);
	if (path === "/") return url.pathname === target;
	return (
		normalize(url.pathname) === normalize(target) ||
		url.pathname.startsWith(normalize(target))
	);
};
---

<header class="site-header" id="main-header">
	<div class="header-bar">
		<a href={withBase("/")} class="wordmark" aria-label={`${wordmark} — início`}>
			{wordmark}
		</a>
		<button class="hamburger" type="button" aria-label="Abrir menu" aria-expanded="false">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>
	<div class="header-nav">
		<div class="header-nav-inner">
			<nav aria-label="Navegação principal">
				<ul class="nav-list">
					{
						menuLinks.map((link, i) => (
							<li style={`--i: ${i}`}>
								<a
									aria-current={isActive(link.path) ? "page" : false}
									class:list={["nav-link", { active: isActive(link.path) }]}
									data-astro-prefetch
									href={withBase(link.path)}
								>
									<Icon name={link.icon} size={13} aria-hidden="true" />
									<span>{link.title}</span>
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</div>
	</div>
</header>

<script>
	const header = document.getElementById("main-header");
	const toggle = header?.querySelector<HTMLButtonElement>(".hamburger");

	toggle?.addEventListener("click", () => {
		const isOpen = header.classList.toggle("is-open");
		toggle.setAttribute("aria-expanded", String(isOpen));
		toggle.setAttribute("aria-label", isOpen ? "Fechar menu" : "Abrir menu");
	});

	window.addEventListener("resize", () => {
		if (window.innerWidth > 768 && header?.classList.contains("is-open")) {
			header.classList.remove("is-open");
			toggle?.setAttribute("aria-expanded", "false");
			toggle?.setAttribute("aria-label", "Abrir menu");
		}
	});

	document.addEventListener("click", (e) => {
		if (header && e.target instanceof Node && !header.contains(e.target)) {
			header.classList.remove("is-open");
			toggle?.setAttribute("aria-expanded", "false");
			toggle?.setAttribute("aria-label", "Abrir menu");
		}
	});

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape" && header?.classList.contains("is-open")) {
			header.classList.remove("is-open");
			toggle?.setAttribute("aria-expanded", "false");
			toggle?.setAttribute("aria-label", "Abrir menu");
			toggle?.focus();
		}
	});

	document.addEventListener("astro:before-swap", () => {
		header?.classList.remove("is-open");
		toggle?.setAttribute("aria-expanded", "false");
		toggle?.setAttribute("aria-label", "Abrir menu");
	});
</script>
