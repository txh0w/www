---
interface Props {
	url: string;
}

const { url } = Astro.props;
---

<div class="share">
	<div class="share-buttons">
		<button
			class="share-btn share-copy"
			type="button"
			data-share-copy
			data-url={url}
			aria-label="Copiar link"
		>
			<svg
				class="icon icon-copy"
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<rect x="9" y="9" width="11" height="11" rx="2"></rect>
				<path d="M5 15V6a2 2 0 0 1 2-2h9"></path>
			</svg>

			<svg
				class="icon icon-check"
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M20 6L9 17l-5-5"></path>
			</svg>

			<span class="sr-only" aria-live="polite" data-copy-status></span>
		</button>
	</div>
</div>

<style>
	.share {
		display: flex;
		justify-content: center;
		margin: 64px 0 0;
	}

	.share-buttons {
		display: inline-flex;
		gap: 10px;
	}

	.share-btn {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: hsl(var(--theme-accent));
		background: var(--accent-soft);
		padding: 8px;
		width: 34px;
		height: 34px;
		border: 1px solid transparent;
		border-radius: 999px;
		cursor: pointer;
		text-decoration: none;
		line-height: 1.4;
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			border-color 0.2s ease;
	}

	.share-btn:hover,
	.share-btn:focus-visible {
		color: hsl(var(--theme-bg));
		background: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}

	.share-btn:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
	}

	.share-btn .icon {
		position: absolute;
		display: inline-block;
		flex-shrink: 0;
		width: 15px;
		height: 15px;
		opacity: 1;
		transform: scale(1);
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
	}

	.share-btn .icon-check {
		opacity: 0;
		transform: scale(0.6);
	}

	.share-copy[data-copied="true"] {
		background: hsl(var(--theme-accent));
		color: hsl(var(--theme-bg));
		border-color: hsl(var(--theme-accent));
	}

	.share-copy[data-copied="true"] .icon-copy {
		opacity: 0;
		transform: scale(0.6);
	}

	.share-copy[data-copied="true"] .icon-check {
		opacity: 1;
		transform: scale(1);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 420px) {
		.share {
			gap: 10px;
		}

		.share-btn {
			padding: 4px 8px;
			font-size: 10.5px;
		}
	}
</style>

<script>
	document.querySelectorAll<HTMLButtonElement>("[data-share-copy]").forEach((btn) => {
		const status = btn.querySelector<HTMLElement>("[data-copy-status]");
		let resetTimeout: ReturnType<typeof setTimeout> | undefined;

		const copyFallback = (text: string) => {
			const textarea = document.createElement("textarea");
			textarea.value = text;
			textarea.setAttribute("readonly", "");
			textarea.style.position = "fixed";
			textarea.style.opacity = "0";
			document.body.appendChild(textarea);
			textarea.select();

			let success = false;

			try {
				success = document.execCommand("copy");
			} catch {
				success = false;
			} finally {
				textarea.remove();
			}

			return success;
		};

		btn.addEventListener("click", async () => {
			const url = btn.dataset.url ?? window.location.href;

			try {
				if (navigator.clipboard?.writeText) {
					await navigator.clipboard.writeText(url);
				} else {
					copyFallback(url);
				}
			} catch {
				copyFallback(url);
			}

			clearTimeout(resetTimeout);

			btn.dataset.copied = "true";
			btn.setAttribute("aria-label", "Copiado");
			if (status) status.textContent = "Copiado";

			resetTimeout = setTimeout(() => {
				delete btn.dataset.copied;
				btn.setAttribute("aria-label", "Copiar link");
				if (status) status.textContent = "";
			}, 1500);
		});
	});
</script>
