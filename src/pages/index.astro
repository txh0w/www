---
import { getAllPosts, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig, socials } from "@/site-config";
import { Icon } from "astro-icon/components";
import { withBase } from "@/utils/path";
import { Image } from "astro:assets";

const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts);
const LATEST_COUNT = 3;
const latestPosts = allPostsByDate.slice(0, LATEST_COUNT);
const archiveCount = allPosts.length;

const handle =
  siteConfig.profile?.github?.split("/").pop() ??
  siteConfig.author.toLowerCase();

const postsLabel =
  archiveCount === 1 ? "publicação" : "publicações";
---

<PageLayout meta={{ title: "Início", description: siteConfig.description }}>
  <div class="linktree">
    <Image
      src={siteConfig.profile?.avatar ?? "/avatar.webp"}
      alt={`Foto de perfil de ${siteConfig.author}`}
      class="linktree-avatar"
      width="96"
      height="96"
      loading="eager"
      decoding="async"
    />
    <span class="linktree-handle">@{handle}</span>
    <h1 class="linktree-name">{siteConfig.author}</h1>
    <p class="linktree-tagline">{siteConfig.description}</p>

    <nav class="linktree-links" aria-label="Redes sociais">
      {
        socials.map((s, index) => (
          <a
            href={s.url}
            target="_blank"
            rel="noreferrer noopener"
            class="linktree-btn"
            aria-label={s.name}
            data-index={index}
          >
            <Icon name={s.icon} size={20} aria-hidden="true" />
            <span>{s.name}</span>
          </a>
        ))
      }
    </nav>

    {
      latestPosts.length > 0 && (
        <section class="linktree-latest" aria-label="Escritos recentes">
          <span class="linktree-latest-label">escritos recentes</span>
          <ul class="linktree-latest-list">
            {latestPosts.map((p, index) => (
              <li>
                <a
                  href={withBase(`/posts/${p.id}/`)}
                  class="linktree-post"
                  data-astro-prefetch
                  data-index={index}
                >
                  {p.data.title}
                </a>
              </li>
            ))}
          </ul>
          <a href={withBase("/posts/")} class="linktree-all" data-astro-prefetch>
            ver todas as {archiveCount} {postsLabel} →
          </a>
        </section>
      )
    }
  </div>
</PageLayout>