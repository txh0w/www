---
import { getAllPosts, getPostSortDate, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig, socials } from "@/site-config";
import { Icon } from "astro-icon/components";
import { absoluteUrl, withBase } from "@/utils/path";
import { Schema } from "astro-seo-schema";

const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts);
const TIMELINE_LIMIT = 5;
const timelinePosts = allPostsByDate.slice(0, TIMELINE_LIMIT);
const featured = timelinePosts[0];
const rest = timelinePosts.slice(1);
const archiveCount = allPosts.length;

const profile = siteConfig.profile;
const siteUrl = (path: string) => absoluteUrl(path, Astro.site);

// Pré-computa data/label do post em destaque uma única vez, em vez de
// chamar getPostSortDate/toLocaleDateString repetidamente no template.
const featuredDate = featured ? getPostSortDate(featured) : null;
const featuredIso = featuredDate ? featuredDate.toISOString() : "";
const featuredLabel = featuredDate ? featuredDate.toLocaleDateString("pt-PT") : "";
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Início",
				item: siteUrl("/"),
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Sobre",
				item: siteUrl("/about"),
			},
			{
				"@type": "ListItem",
				position: 3,
				name: "Publicações",
				item: siteUrl("/posts"),
			},
		],
	}}
/>

<PageLayout meta={{ title: "Início", description: siteConfig.description }}>
	<section class="hero">
		<div class="hero-header">
			{
				profile?.avatar && (
					<img src={profile.avatar} alt={siteConfig.author} class="avatar" width="56" height="56" />
				)
			}
			<div class="hero-title">
				<h1>{siteConfig.author}</h1>
				<span class="hero-status">everything is going to be okay...</span>
			</div>
		</div>
		<p>{siteConfig.description}</p>
		<div class="socials">
			{
				socials.map((s, i) => (
					<>
						<a href={s.url} rel="noreferrer" target="_blank" aria-label={s.name}>
							<Icon name={s.icon} size={18} />
						</a>
					</>
				))
			}
		</div>
	</section>

	<section class="writing" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">escritos</div>
		<div class="timeline">
			{
				featured && (
					<a
						class="post featured"
						data-astro-prefetch
						href={withBase(`/posts/${featured.id}/`)}
						style="--i: 0"
					>
						<div class="post-rail">
							<time class="post-date" datetime={featuredIso}>
								{featuredLabel}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<div class="post-stamp">mais recente · {featuredLabel}</div>
							<h2 class="post-title">{featured.data.title}</h2>
							<p class="post-excerpt">{featured.data.description}</p>
							{!!featured.data.tags?.length && (
								<div class="post-meta">
									{featured.data.tags.map((t, i) => (
										<Fragment>
											{i > 0 && <span class="dot">·</span>}
											<span>{t}</span>
										</Fragment>
									))}
								</div>
							)}
						</div>
					</a>
				)
			}

			{
				rest.map((p, idx) => (
					<a
						class="post"
						data-astro-prefetch
						href={withBase(`/posts/${p.id}/`)}
						style={`--i: ${idx + 1}`}
					>
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(p).toISOString()}>
								{getPostSortDate(p).toLocaleDateString("pt-PT")}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<h3 class="post-title">{p.data.title}</h3>
							<p class="post-preview">{p.data.description}</p>
						</div>
					</a>
				))
			}

			<div class="archive-link" style={`--i: ${rest.length + 1}`}>
				<a data-astro-prefetch href={withBase("/posts/")}
					>ver todas as {archiveCount} publicações →</a
				>
			</div>
		</div>
	</section>
</PageLayout>

<style>
	/* ---------- Hero ---------- */
	.hero {
		margin-bottom: 76px;
	}
	.hero-header {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 16px;
	}

	.avatar {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		object-fit: cover;
		border: 1px solid var(--hairline);
		box-shadow: 0 0 0 3px hsl(var(--theme-bg));
		flex-shrink: 0;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease;
	}
	.hero-header:hover .avatar {
		transform: translateY(-1px);
		border-color: hsl(var(--theme-accent));
	}
	.hero h1 {
		font-size: clamp(2.2rem, 6vw, 4.2rem);
		line-height: 0.95;
		letter-spacing: -0.05em;
		margin: 0;
		font-weight: 700;
		text-wrap: balance;
		font-family: var(--font-serif);
	}
	.hero p {
		font-size: 18px;
		line-height: 1.65;
		color: hsl(var(--theme-text));
		margin: 0 0 22px;
		max-width: 60ch;
		text-wrap: pretty;
		white-space: pre-line;
	}
	.socials {
		font-family: var(--font-sans);
		font-size: 13px;
		color: hsl(var(--theme-text) / 0.72);
		margin-top: 16px;
		display: flex;
		align-items: center;
		gap: 10px;
		flex-wrap: wrap;
	}
	.socials a {
		color: hsl(var(--theme-text-muted));
		transition: color 0.2s ease;
	}
	.socials a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	/* Removed .socials .sep rule */

	/* ---------- Writing timeline ---------- */
	.writing {
		margin-bottom: 84px;
	}
	/* ---------- Featured post ---------- */
	.post.featured .post-body {
		padding-bottom: 56px;
	}
	.post.featured .post-stamp {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: 0.12em;
		text-transform: lowercase;
		color: hsl(var(--theme-accent));
		margin-bottom: 12px;
	}
	.post.featured .post-title {
		font-size: clamp(1.8rem, 4vw, 2.4rem);
		line-height: 1.14;
		margin-bottom: 14px;
		letter-spacing: -0.03em;
	}
	.post.featured .post-excerpt {
		font-size: 18px;
		line-height: 1.62;
		color: hsl(var(--theme-text-muted));
		margin: 0 0 16px;
		max-width: 58ch;
		word-wrap: break-word;
		overflow-wrap: break-word;
	}
	.post.featured .post-meta {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: hsl(var(--theme-text) / 0.72);
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
	}
	.post.featured .post-meta .dot {
		color: var(--faint);
		margin: 0 8px;
	}
	.post.featured .post-dot {
		--rail-dot-size: 11px;
		border-color: hsl(var(--theme-text-muted));
	}
	.post.featured:hover .post-dot {
		background: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}

	.archive-link {
		grid-column: 2;
		margin-top: 8px;
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.72);
	}
	.archive-link a {
		display: inline-block;
		padding: 6px 0;
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition:
			color 0.2s ease,
			text-decoration-color 0.2s ease,
			transform 0.2s ease;
	}
	.archive-link a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
		transform: translateX(3px);
	}
	.hero-title {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.hero-status {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: 0.12em;
		text-transform: lowercase;
		color: hsl(var(--theme-accent));
	}

	.socials a:focus-visible,
	.archive-link a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.hero {
			margin-bottom: 56px;
		}
		.hero p {
			font-size: 18px;
		}
		.post.featured .post-rail {
			display: none;
		}
		.post.featured .post-body {
			padding-bottom: 24px;
			border-bottom: 1px solid var(--hairline);
			margin-bottom: 4px;
		}
		.post.featured .post-title {
			font-size: 22px;
			line-height: 1.2;
			letter-spacing: -0.015em;
			margin-bottom: 10px;
		}
		.post.featured .post-excerpt {
			font-size: 15.5px;
			line-height: 1.55;
			margin: 0 0 10px;
		}
		.post.featured .post-meta {
			font-size: 11px;
		}
		.archive-link {
			margin-top: 0;
		}
	}

	@media (max-width: 420px) {
		.hero {
			margin-bottom: 48px;
		}
		.hero p {
			font-size: 17px;
		}
		.socials {
			font-size: 12.5px;
		}
		.socials .sep {
			margin: 0 6px;
		}
		.writing {
			margin-bottom: 64px;
		}
		.post.featured .post-title {
			font-size: 17px;
		}
		.post.featured .post-excerpt {
			font-size: 15px;
		}
		.hero-header {
			gap: 12px;
		}

		.avatar {
			width: 46px;
			height: 46px;
		}
		.hero-status {
			font-size: 10px;
		}
	}
</style>
