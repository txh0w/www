---
import PageLayout from "@/layouts/Base.astro";
import { withBase } from "@/utils/path";

const meta = {
	description: "A página que você estava procurando não existe.",
	title: "404 — Não encontrado",
};
---

<PageLayout meta={meta}>
	<section class="not-found max-w-[44ch] py-6 pb-20">
		<div
			class="eyebrow text-text/45 mb-4 font-mono text-[11px] font-medium tracking-[0.18em] uppercase"
		>
			404
		</div>
		<h1
			class="text-text m-0 mb-3 font-serif leading-[1.12] font-normal tracking-[-0.02em]"
			style="font-size: clamp(28px, 5vw, 40px)"
		>
			não encontrado
		</h1>
		<p class="text-text m-0 text-[16px] leading-[1.8]">
			oops! a pagina que você ta procurando não existe
			<a
				class="border-accent/40 text-accent motion-safe:ease hover:border-accent hover:text-text border-b motion-safe:transition-colors motion-safe:duration-[0.2s]"
				href={withBase("/")}>Início</a
			>
			·
			<a
				class="border-accent/40 text-accent motion-safe:ease hover:border-accent hover:text-text border-b motion-safe:transition-colors motion-safe:duration-[0.2s]"
				href={withBase("/posts/")}>Arquivo</a
			>
		</p>
	</section>
</PageLayout>
