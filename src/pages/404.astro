---
import PageLayout from "@/layouts/Base.astro";
import { withBase } from "@/utils/path";

const meta = {
	description: "A página que você estava procurando não existe.",
	title: "404 — Não encontrado",
};
---

<PageLayout meta={meta}>
	<section class="not-found">
		<div class="eyebrow">404</div>
		<h1>não encontrado</h1>
		<p>
			oops! a pagina que você ta procurando não existe
			<a href={withBase("/")}>Início</a>
			·
			<a href={withBase("/posts/")}>Arquivo</a>
		</p>
	</section>
</PageLayout>

<style>
	.not-found {
		padding: 24px 0 80px;
		max-width: 44ch;
	}
	.eyebrow {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.45);
		margin-bottom: 16px;
	}
	.not-found h1 {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: clamp(28px, 5vw, 40px);
		letter-spacing: -0.02em;
		line-height: 1.12;
		color: hsl(var(--theme-text));
		margin: 0 0 12px;
	}
	.not-found p {
		font-size: 16px;
		line-height: 1.8;
		color: hsl(var(--theme-text));
		margin: 0;
	}
	.not-found a {
		color: hsl(var(--theme-accent));
		border-bottom: 1px solid hsl(var(--theme-accent) / 0.4);
		transition: border-color 0.2s ease;
	}
	.not-found a:hover {
		border-color: hsl(var(--theme-accent));
		color: hsl(var(--theme-text));
	}
</style>
